# Evolution API - Hostinger Node.js (MySQL)
# Copie estas variáveis para o painel da Hostinger

DATABASE_PROVIDER=mysql
DATABASE_CONNECTION_URI=mysql://usuario:senha@localhost:3306/evolution_db
DATABASE_CONNECTION_CLIENT_NAME=evolution_lunins

CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

AUTHENTICATION_API_KEY=GERE_UMA_CHAVE_FORTE_AQUI
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

SERVER_URL=https://evolution.seudominio.com
SERVER_PORT=8080
