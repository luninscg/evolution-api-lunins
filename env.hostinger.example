# Variáveis essenciais para Hostinger Node.js
# Copie para .env e preencha os valores. O .env.example completo tem todas as opções.

SERVER_URL=https://seu-dominio.hostinger.com
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI='postgresql://user:senha@host:5432/evolution_db'

# Sem Redis - use cache local
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

# Chave obrigatória - altere!
AUTHENTICATION_API_KEY=SuaChaveSecretaAqui
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false
